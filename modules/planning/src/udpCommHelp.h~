/**
 * udpCommHelp 类用于处理UDP通信，包括发送和接收消息。
 */
class udpCommHelp {
public:
    /**
     * 发送消息。
     * @param message 待发送的字节数组。
     */
    void sendMsg(const std::vector <uint8_t> &message);

    /**
     * 打印消息内容为十六进制格式。
     * @param message 待打印的消息内容。
     */
    void printHex(const std::vector <uint8_t> &message);

    /**
     * 析构函数，释放资源。
     */
    ~udpCommHelp();

    /**
     * 初始化服务端套接字，绑定到指定IP和端口。
     * @param localPort 本地端口。
     * @param localIP 本地IP地址。
     */
    void initServerSock_Lidar_B3(int localPort, std::string localIP);

    /**
     * 初始化客户端套接字，连接到指定的服务器。
     * @param destPort 目标端口。
     * @param destIP 目标IP地址。
     */
    void initClientSock_ZC(int destPort, std::string destIP);

    /**
     * 初始化服务器套接字，用于ZC模块。
     * @param ip 本地IP。
     * @param port 本地端口。
     */
    void initServerZc(const string &ip, int port);

    /**
     * 处理接收到的数据。
     * @param receivedBuffer 数据缓冲区。
     * @param bufferSize 缓冲区大小。
     */
    void processReceivedData(const uint8_t *receivedBuffer, size_t bufferSize);

    /**
     * 从客户端套接字接收数据。
     * @param data 数据缓冲区。
     * @param buffSize 缓冲区大小。
     * @return 接收到的字节数。
     */
    ssize_t recvData_clientSock_zc(unsigned char *data, size_t buffSize);

private:
    int tempSocket;               // 临时套接字
    sockaddr_in addrFrom;         // 远程地址
};
