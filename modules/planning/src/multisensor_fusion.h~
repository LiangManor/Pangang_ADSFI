    //发送数据到车控
    void getFusionSend();

    explicit MultisensorFusion(std::string configFile); //: node(configFile)
    ~MultisensorFusion();
    //初始化当前进程的node节点
    Adsfi::HafStatus Init() 
    {
        return node.Init();
    };

    //停止node节点
    void Stop() {
        node.Stop();
        return;
    };

    bool IsError() const {
        return errorStatus;
    }

    //获取车控发送来的数据
    void getZcData();
    //进程管理
    void Process();
    // 求解另一端的坐标
    void getAnotherXY(const float tailX,const float tailY,const float tailYaw, float & headX, float & headY)//unit: rad
    {
        // 判断象限
        int num = 0;
        if( (0. <= tailYaw) && (tailYaw < (3.1415926/2)) ) num = 1;                // 第1象限
        else if ( (3.1415926/2 <= tailYaw) && (tailYaw < (3.1415926)) ) num = 2;   // 第2象限
        else if ( (-3.1415926  <= tailYaw) && (tailYaw < (-3.1415926/2)) ) num = 3;// 第3象限
        else if ( (-3.1415926/2  <= tailYaw) && (tailYaw < 0.) )num = 4;           // 第4象限
        // 计算坐标
        if (num == 1) 
        {
            headY = tailY - std::abs(10.755*sin(tailYaw));
            headX = tailX - std::abs(10.755*cos(tailYaw));
        }
        else if(num == 2)
        {
            headY = tailY - std::abs(10.755*sin(tailYaw));
            headX = tailX + std::abs(10.755*cos(tailYaw));
        }
        else if(num == 3)
        {
            headY = tailY + std::abs(10.755*sin(tailYaw));
            headX = tailX + std::abs(10.755*cos(tailYaw));
        }
        else if(num == 4)
        {
            headY = tailY + std::abs(10.755*sin(tailYaw));
            headX = tailX - std::abs(10.755*cos(tailYaw));
        }
    }
    float getAnotherYaw(const float yaw_)
    {
    	float anotherYaw = yaw_ + 3.1415926;
        // 调整到[-π, π)范围内
    	anotherYaw = fmod(anotherYaw + 3.1415926, 2 * 3.1415926);
        if (anotherYaw < 0)
        {
        	anotherYaw += 2 * 3.1415926;  // 调整为正数
        }
        anotherYaw -= 3.1415926;
        return anotherYaw;
    }

private:

    bool errorStatus{false};

    Adsfi::PlanningBase node;
    uint32_t seq = 1U;
    std::vector <std::thread> pool;
    bool isThreadRunning = true;
    udpCommHelp udpHelp;

};



