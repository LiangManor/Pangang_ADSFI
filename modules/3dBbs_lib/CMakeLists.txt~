cmake_minimum_required(VERSION 3.5)
project(bbs3d)
SET(CMAKE_BUILD_TYPE Release)
set(CMAKE_MODULE_PATH ${CMAKE_MODULE_PATH} "${CMAKE_CURRENT_LIST_DIR}/cmake")

find_package(Eigen3 REQUIRED)

## find OpenMP
find_package(OpenMP)
set (CMAKE_C_FLAGS "${CMAKE_C_FLAGS} ${OpenMP_C_FLAGS}")
set (CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} ${OpenMP_CXX_FLAGS}")

include_directories(
  ${CMAKE_CURRENT_SOURCE_DIR}/include
  $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/include>
  $<INSTALL_INTERFACE:include>
)

add_library(cpu_bbs3d
  SHARED
  src/bbs3d.cpp
  /home/qjj/4.lib/src/voxelmaps.cpp
)

add_custom_command(TARGET cpu_bbs3d POST_BUILD
  COMMAND ${CMAKE_COMMAND} -E copy $<TARGET_FILE:cpu_bbs3d> ${CMAKE_CURRENT_SOURCE_DIR}/lib/
  COMMENT "Copying cpu_bbs3d library to lib folder"
)

