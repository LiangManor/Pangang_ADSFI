void LidarDetection::SubLocation()
{
    while (!node.IsStop()) 
    {
        std::shared_ptr<HafLocation> location;
        if (node.GetLocation(location) != HAF_SUCCESS) 
        {
            Stop();
            return;
        }
        this->curX = location->pose.pose.position.x;
        this->curY = location->pose.pose.position.y;
        this->curZ = location->pose.pose.position.z;
        std::cout << "Location x: " << this->curX<<std::endl;
        std::cout << "Location y: " << this->curY<<std::endl;
        std::cout << "Location z: " << this->curZ<<std::endl;
    }
    return;
}

