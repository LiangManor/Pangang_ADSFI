#include "ground_segmentation_inwinic.h"



GroundSegmentation::GroundSegmentation(GroundSegmentationParams params)
{
   params_ = params;
   Segment segment(params.n_bins, // 实例化Segment类------------1
                   params.min_slope,//-----------------------2
                   params.max_slope,//-----------------------3
                   params.max_error_square,//-----------------------4
                   params.long_threshold,//-----------------------5
                   params.max_long_height,//-----------------------6
                   params.max_start_height,//-----------------------7
                   params.sensor_height);//-----------------------8
   segments_ = std::vector<Segment>(params.n_segments, segment);//指定容器大小和内部元素的值
}
GroundSegmentation::~GroundSegmentation() {}

//功能函数1
float GroundSegmentation::fastAtan2(float y, float x)
{
  float atan2_p1 = 0.9997878412794807f * (float)(180 / M_PI);
  float atan2_p3 = -0.3258083974640975f * (float)(180 / M_PI);
  float atan2_p5 = 0.1555786518463281f * (float)(180 / M_PI);
  float atan2_p7 = -0.04432655554792128f * (float)(180 / M_PI);
  float ax = std::abs(x);
  float ay = std::abs(y); // 首先不分象限，求得一个锐角角度
  float a, c, c2;
  if (ax >= ay)
  {
    c = ay / (ax + (float)DBL_EPSILON);
    c2 = c * c;
    a = (((atan2_p7 * c2 + atan2_p5) * c2 + atan2_p3) * c2 + atan2_p1) * c;
  }
  else
  {
    c = ax / (ay + (float)DBL_EPSILON);
    c2 = c * c;
    a = 90.f - (((atan2_p7 * c2 + atan2_p5) * c2 + atan2_p3) * c2 + atan2_p1) * c;
  }

  if (x < 0) // 锐角求出后，根据x和y的正负性确定向量的方向，即角度。
    a = 180.f - a;
  if (y < 0)
    a = 360.f - a;
  return a * M_PI / 180;
}

//————————————————————————————算法入口
void GroundSegmentation::segment(      pcl::PointCloud<PointT>::Ptr cloud,
                                       pcl::PointCloud<PointT>::Ptr ground_pc,
                                       pcl::PointCloud<PointT>::Ptr non_ground_pc)
{

  insertPoints(cloud);
  getLines();
  assignCluster(cloud, ground_pc, non_ground_pc);
}

//步骤1:
void GroundSegmentation::insertPoints( pcl::PointCloud<PointT>::Ptr cloud)
{
  //设置点云对应的segment、bin
  point_segment_bin_idx.resize(cloud->size()); 
  //设置点云对应的新坐标
  new_coordinates.resize(cloud->size());
  
  float segment_step = 2 * M_PI / params_.n_segments;
  float bin_step = (params_.r_max_ - params_.r_min_) / params_.n_bins;
  float r_max2 = params_.r_max_ * params_.r_max_;
  float r_min2 = params_.r_min_ * params_.r_min_;
  std::pair<int, int> invalid_point = std::make_pair<int, int>(-1, -1);
  
  for (size_t i = 0; i < cloud->size(); ++i)
  {
       PointT point(cloud->at(i));
       
       //——1——判断点云是否在ROI区域，不在ROI区域，则认为是无效点
       float range_square = point.x * point.x + point.y * point.y;

       if (range_square > r_max2 || range_square < r_min2)
       {
         point_segment_bin_idx[i] = invalid_point;
         continue;
       }
       
       //——2——判断点云在哪个bin上
       float range = sqrt(range_square);
       int bin_index = (range - params_.r_min_) / bin_step;
       
       //——3——判断点云在那个segment上
       float angle = fastAtan2(point.y, point.x);
       int segment_index = angle / segment_step;
       //防止越界
       segment_index = segment_index == params_.n_segments ? 0 : segment_index;
       //记录每一个bin里的最佳点（最佳点定义:z值最低的点）
       segments_[segment_index].bins_[bin_index].addPoint(range, point.z);
       //记录ROI区域内的点云对应的segment与bin序号
       point_segment_bin_idx[i] = std::make_pair(segment_index, bin_index);
       //记录点云对应的新坐标
       new_coordinates[i] = Bin::MinZPoint(range, point.z);
  }
}

//步骤2:拟合每一个segment上的线
void GroundSegmentation::getLines()
{
  for (int i = 0; i < params_.n_segments; i++)
  {
    segments_[i].fitSegmentLines();
  }
}

//步骤3:分配点云
void GroundSegmentation::assignCluster(   pcl::PointCloud<PointT>::Ptr cloud,
                                          pcl::PointCloud<PointT>::Ptr ground_pc,
                                          pcl::PointCloud<PointT>::Ptr non_ground_pc)
{
  float segment_step = 2 * M_PI / params_.n_segments; // 0.035
  for (size_t i = 0; i < cloud->size(); ++i)
  {
    PointT point(cloud->at(i));
    if (point_segment_bin_idx[i].first == -1 && point_segment_bin_idx[i].second == -1)
    {
      non_ground_pc->points.emplace_back(point);
      continue;
    }
    int segment_index = point_segment_bin_idx[i].first; // 点所在的seg
    int bin_index = point_segment_bin_idx[i].second;
    Bin::MinZPoint point_2d = new_coordinates[i]; // 每个点的2d形式
    Bin::MinZPoint minz_point = segments_[segment_index].bins_[bin_index].getMinZPoint();
    auto min_z_ = minz_point.z;

    float dist = segments_[segment_index].verticalDistanceToLine(point_2d.d, point_2d.z); // 点到直线的距离
    
    // Search neighboring segments.
    int steps = 1;
    while (dist < 0 && steps * segment_step < params_.line_search_angle)
    {
      int index_1 = std::min(segment_index + steps, params_.n_segments - 1);
      int index_2 = std::max(segment_index - steps, 0);

      float dist_1 = segments_[index_1].verticalDistanceToLine(point_2d.d, point_2d.z);
      float dist_2 = segments_[index_2].verticalDistanceToLine(point_2d.d, point_2d.z);
      if (dist_1 >= 0)
          dist = dist_1;
      if (dist_2 >= 0)
      {
          if (dist < 0 || dist_2 < dist)
          dist = dist_2;
      }
      if((dist_1 >= 0)&&(dist_2 >= 0)){};
      steps += 2;
    }
    if (dist < params_.max_dist_to_line && dist != -1 && std::fabs(point_2d.z - min_z_) < params_.max_dist_to_line)
      ground_pc->points.emplace_back(point);
    else
      non_ground_pc->points.emplace_back(point);
  }
  // 二次筛选
  float mean_z = 0.0;
  for(size_t i = 0; i < ground_pc->size(); ++i)
  {
  	mean_z += ground_pc->points[i].z;
  }
  mean_z = mean_z / ground_pc->size();
  pcl::PointCloud<PointT>::Ptr non_ground_pc_temp (new pcl::PointCloud<PointT>);
  for(size_t i = 0; i < non_ground_pc->size(); ++i)
  {
	  if(non_ground_pc->points[i].z <= mean_z + 0.05)// ----------------
	  {
		  ground_pc->points.emplace_back(non_ground_pc->points[i]);
	  }
	  else
	  {
		  non_ground_pc_temp->points.emplace_back(non_ground_pc->points[i]);
	  }
  }
  non_ground_pc->clear();
  *non_ground_pc += *non_ground_pc_temp;

}
