/*      second_init_ = false;*/
/*      this->x_post_<< state.x, state.y, state.v, state.yaw, state.yawRate;*/
/*   }*/
}

void EKF::update(const vehicleState state)
{
   //传感器测量值
   Eigen::MatrixXf meas;
   meas.resize(2, 1);
   meas<< state.x, state.y;
   //计算卡尔曼增益
   this->kGain = this->p_pre_ * H.transpose() * this->s_pre_.inverse();
   //计算后验估计 与 后验估计协方差矩阵
   this->x_post_ = this->x_pre_ + this->kGain * ( meas - this->z_pre_);
   this->p_post_ = this->p_pre_ - this->kGain * H * this->p_pre_;
   // 是否需要对后验估计协方差矩阵进行修正？
   // 当协方差的某个特征值大于阈值，则说明对应的估计值估计已经发散，需要进行纠正
   std::cout<<"speed = "<<this->x_post_(2,0)<<std::endl;
