							}
							else
							{
								//HAF_LOG_INFO << "lidar_slam Pub OK";
							}
						}
						std::this_thread::sleep_for(std::chrono::milliseconds(50));//延时100ms
						return;
					}
				}
				// 以上两个条件不满足，则等待下一轮循环再进行初始化工作。
				else// 进入该else程序块表示 当前进程没有与rfid主机建立udp通讯
				{
					std::cout<<"2使用RTK数据不稳定，且rfid主机链接不上"<<std::endl;
