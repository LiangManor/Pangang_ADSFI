					if (node.SendLidarSlam(out) != HAF_SUCCESS)
					{
						std::cout<<"send lidar_slam location data failed!"<<std::endl;
					}
					else
					{
						//HAF_LOG_INFO << "lidar_slam Pub OK";
					}
				}
