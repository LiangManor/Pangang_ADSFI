#include "lidar_slam.h"
// 融合定位头文件
#include "ekf.h"


using namespace std;
using namespace Adsfi;



mdc::visual::PointCloud<mdc::visual::PointXYZRGB> lidarHistoryTrajectory;
mdc::visual::PointCloud<mdc::visual::PointXYZRGB> gpsHistoryTrajectory;
// 车辆状态
vehicleState egoState;
// 卡尔曼滤波器
EKF ekfFilter;
// 记录上一时刻的时间戳
std::chrono::high_resolution_clock::time_point prevTimeStamp;
// imu 计算出的速度分量
float vxImu = 0.0;
float vyImu = 0.0;




void LidarSlam::Process()
{
    pcl::PointCloud<pcl::PointXYZ>::Ptr alignedPC(new pcl::PointCloud<pcl::PointXYZ>);
     // 先用ndt定位给车辆状态初始化
    if(!egoState.init)
    {
        auto curLidar = node.GetLidar(1);
        
        if (!curLidar.empty()) //如果获取到点云数列
        {
            pcl::PointCloud<pcl::PointXYZ>::Ptr currentScanPC(new pcl::PointCloud<pcl::PointXYZ>);
            pcl::PointXYZ p;
            for (size_t i = 0; i < curLidar.front()->pointCloud.size(); i++)
            {
                p.x = curLidar.front()->pointCloud[i].x;
                p.y = curLidar.front()->pointCloud[i].y;
                p.z = curLidar.front()->pointCloud[i].z;
                currentScanPC->push_back(p);
            }
            
            alignedPC = align(currentScanPC);
            // 标记车辆已被初始化的状态
            egoState.init = true;
            // 初始化车辆状态
            Eigen::Matrix3f submatrix = lastLocation.block<3, 3>(0, 0);
            Eigen::Vector3f delta_euler = submatrix.eulerAngles(2,1,0);// 旋转矩阵解算出欧拉角
            egoState.x       = lastLocation(0, 3);
            egoState.y       = lastLocation(1, 3);
            egoState.yaw     = delta_euler(0);
            egoState.v       = 0.;
            egoState.yawRate = 0.;
            // 记录当前时间戳
            prevTimeStamp = std::chrono::high_resolution_clock::now();
        }
        else
        {
            return;
        }
    }
    // 车辆状态已经进行了初始化
    else
    {
        auto curImu = node.GetImu(1);
        if (!curImu.empty())
        {
            auto now = std::chrono::high_resolution_clock::now();// 获取当前时间戳
            std::chrono::milliseconds diff = std::chrono::duration_cast<std::chrono::milliseconds>(now - prevTimeStamp);
            prevTimeStamp = now;
            float dt = (static_cast<float>(diff.count())) / 1000.0;// 毫秒换算成秒
            vxImu    = vxImu + dt * curImu.front()->linearAcceleration.x;
            vyImu    = vyImu + dt * curImu.front()->linearAcceleration.y;
            float v  = std::sqrt(vxImu*vxImu + vyImu*vyImu);
            // 更新imu提供的车辆状态
            egoState.v       = v;
            egoState.yawRate = curImu.front()->angularVelocity.z;
            egoState.dt      = dt;
        }
        
        auto curLidar = node.GetLidar(1);
        if (!curLidar.empty())// 有 lidar定位数据 则对定位结果进行矫正
        {
            pcl::PointCloud<pcl::PointXYZ>::Ptr currentScanPC(new pcl::PointCloud<pcl::PointXYZ>);
            pcl::PointXYZ p;
            for (size_t i = 0; i < curLidar.front()->pointCloud.size(); i++)
            {
                p.x = curLidar.front()->pointCloud[i].x;
                p.y = curLidar.front()->pointCloud[i].y;
                p.z = curLidar.front()->pointCloud[i].z;
                currentScanPC->push_back(p);
            }
            alignedPC = align(currentScanPC);
            // 进行融合
            egoState.lidarLocation  = true;// 使能融合 enable
            // 获取lidar的xy定位结果
            egoState.lidarLocationX = this->lastLocation(0, 3);
            egoState.lidarLocationY = this->lastLocation(1, 3);
            // 获取lidar的定位航向角
            Eigen::Matrix3f submatrix   = this->lastLocation.block<3, 3>(0, 0);
            Eigen::Vector3f delta_euler = submatrix.eulerAngles(2,1,0);// 旋转矩阵解算出欧拉角
            egoState.yaw            = delta_euler(0);
            // 进行卡尔曼融合，利用 lidar 定位结果进行纠正
            ekfFilter.run(egoState);
        }
        else// 反之只利用imu数据进行迭代推算
        {
            // 只进行预测
            ekfFilter.run(egoState);
        }
    }
    // 更新本轮定位结果
    pcl::PointXYZ pointFilter;
    pointFilter.x = ekfFilter.x_post_(0,0);
    pointFilter.y = ekfFilter.x_post_(1,0);
    pointFilter.z = this->lastLocation(2, 3);
    Eigen::Translation3f init_translation(pointFilter.x, pointFilter.y, pointFilter.z);
    Eigen::Matrix3f submatrix = this->lastLocation.block<3, 3>(0, 0);
    Eigen::Vector3f delta_euler = submatrix.eulerAngles(2,1,0);// 旋转矩阵解算出欧拉角
    Eigen::AngleAxisf init_rotation_x(delta_euler(2), Eigen::Vector3f::UnitX());//roll
    Eigen::AngleAxisf init_rotation_y(delta_euler(1), Eigen::Vector3f::UnitY());//pitch
    Eigen::AngleAxisf init_rotation_z(egoState.yaw, Eigen::Vector3f::UnitZ());//yaw
    this->lastLocation = (init_translation * init_rotation_z * init_rotation_y * init_rotation_x).matrix();





}







